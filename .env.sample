# Copy this file to .env and fill in any values before running.
# This project uses the NYC Open Data Socrata API which requires no authentication
# for public datasets, so no API key is needed by default.

# Set to "true" to enable verbose debug logging in the pipeline
DEBUG=false

# Optional: force the pipeline to re-download from the API even if the local
# CSV cache is current (useful when testing the extract step in isolation)
# FORCE_API_CALL=false

# Optional: force the pipeline to reload the database even if it is already
# up to date with the API
# FORCE_DB=false
